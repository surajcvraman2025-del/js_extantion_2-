{
  "manifest_version": 3,
  "name": "cute_url_saver",
  "version": "1.0",
  "description": "cute_url_saver",

  "permissions": ["tabs", "sidePanel"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": "icon.png"
  },

  "side_panel": {
    "default_path": "index.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}